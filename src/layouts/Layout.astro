---
export interface Props {
  title: string;
  description: string;
  image?: string;
}

const {
  title,
  description,
  image = 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1200&h=630&fit=crop&q=82',
} = Astro.props;

const canonical = Astro.url.href;
const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Máquina de Costura Singer Facilita Pro 4423 220V',
  brand: { '@type': 'Brand', name: 'Singer' },
  model: 'Facilita Pro 4423',
  sku: 'B07Y8NSHCJ',
  description,
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.8',
    reviewCount: '2798',
  },
  offers: {
    '@type': 'Offer',
    url: 'https://amzn.to/4dObHF0',
    priceCurrency: 'BRL',
    availability: 'https://schema.org/InStock',
  },
});
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#2f241d" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:site_name" content="Escolha Certa Brasil" />
    <meta property="og:locale" content="pt_BR" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <script type="application/ld+json" set:html={schema} />

    <style>
      :root {
        --paper: #fbf7f1;
        --surface: #fffdf9;
        --ink: #2f241d;
        --muted: #6f6259;
        --line: #eadfd3;
        --accent: #a8693f;
        --accent-dark: #7a4527;
        --soft: #f1e6db;
        --green: #206a43;
        --shadow: 0 18px 60px rgba(47, 36, 29, 0.1);
        --green-50: #eef8f2;
        --green-100: #d9efdf;
        --green-200: #bfe4ca;
        --green-600: #2f8757;
        --green-700: #206a43;
        --gray-50: #f8f5f0;
        --gray-100: #efe7dd;
        --gray-200: #e4d8cc;
        --gray-300: #d6c7b8;
        --gray-400: #a89889;
        --gray-500: #77695f;
        --gray-600: #5f5149;
        --gray-700: #493d36;
        --gray-800: #382e28;
        --gray-900: #2f241d;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        color: var(--ink);
        background: var(--paper);
        font-family: Georgia, 'Times New Roman', serif;
        line-height: 1.65;
      }

      img {
        display: block;
        max-width: 100%;
        height: auto;
      }

      a {
        color: inherit;
      }

      .page {
        width: min(100% - 48px, 940px);
        margin: 28px auto;
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 28px;
        overflow: hidden;
        box-shadow: var(--shadow);
      }

      .wrap {
        width: min(100% - 64px, 760px);
        margin: 0 auto;
      }

      .wide {
        width: min(100% - 64px, 840px);
        margin: 0 auto;
      }

      h1,
      h2,
      h3,
      p {
        margin-top: 0;
      }

      h1 {
        font-size: clamp(2.25rem, 6vw, 4.4rem);
        line-height: 0.98;
        letter-spacing: -0.055em;
        margin-bottom: 24px;
      }

      h2 {
        font-size: clamp(1.85rem, 4vw, 3rem);
        line-height: 1.05;
        letter-spacing: -0.04em;
        margin-bottom: 18px;
      }

      h3 {
        font-size: 1.15rem;
        line-height: 1.25;
        margin-bottom: 8px;
      }

      p {
        color: var(--muted);
        font-size: 1.08rem;
      }

      .eyebrow {
        display: block;
        color: var(--accent-dark);
        font-family: Arial, sans-serif;
        font-size: 0.76rem;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        margin-bottom: 14px;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 52px;
        padding: 0 26px;
        border-radius: 999px;
        background: var(--ink);
        color: #fff;
        font-family: Arial, sans-serif;
        font-size: 0.95rem;
        font-weight: 700;
        text-decoration: none;
        border: 1px solid var(--ink);
      }

      .btn:hover {
        background: var(--accent-dark);
        border-color: var(--accent-dark);
      }

      .btn.secondary {
        background: transparent;
        color: var(--ink);
      }

      .section {
        padding: 72px 0;
        border-top: 1px solid var(--line);
      }

      @media (max-width: 720px) {
        .page {
          width: calc(100% - 18px);
          margin: 9px auto;
          border-radius: 20px;
        }

        .wrap,
        .wide {
          width: calc(100% - 34px);
        }

        .section {
          padding: 52px 0;
        }

        p {
          font-size: 1rem;
        }
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
