---
export interface Props {
  title: string;
  description: string;
  image?: string;
  canonical?: string;
  type?: string;
}

const {
  title,
  description,
  image = 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1200&h=630&fit=crop&q=80',
  canonical,
  type = 'website',
} = Astro.props;

const siteUrl = 'https://singer4423.escolhacertabrasil.com.br';
const canonicalURL = canonical ?? Astro.url.href;
const ogImage = image.startsWith('http') ? image : `${siteUrl}${image}`;

const schemaProduct = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Singer Facilita Pro 4423 220V',
  description:
    'Máquina de Costura Singer Facilita Pro 4423 com 23 pontos, 1100 pontos por minuto, passador automático e casa de botão automática.',
  brand: { '@type': 'Brand', name: 'Singer' },
  sku: 'B07Y8NSHCJ',
  model: 'Facilita Pro 4423',
  color: 'Branco',
  material: 'Metal',
  offers: {
    '@type': 'Offer',
    url: 'https://amzn.to/4dObHF0',
    priceCurrency: 'BRL',
    availability: 'https://schema.org/InStock',
    seller: { '@type': 'Organization', name: 'Amazon' },
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.8',
    reviewCount: '2798',
    bestRating: '5',
    worstRating: '1',
  },
});
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#7c3aed" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.svg" />

    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Singer Facilita Pro 4423 — Sua primeira máquina séria" />
    <meta property="og:site_name" content="Escolha Certa Brasil" />
    <meta property="og:locale" content="pt_BR" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Singer Facilita Pro 4423" />

    <script type="application/ld+json" set:html={schemaProduct} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,700;1,500&display=swap" rel="stylesheet" />
    <link rel="preconnect" href="https://images.unsplash.com" />
    <link rel="dns-prefetch" href="https://amzn.to" />

    <style>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --rose-50: #fff1f2;
        --rose-100: #ffe4e6;
        --rose-200: #fecdd3;
        --rose-400: #fb7185;
        --rose-500: #f43f5e;
        --rose-600: #e11d48;
        --rose-700: #be123c;
        --rose-900: #881337;

        --purple-50: #faf5ff;
        --purple-100: #f3e8ff;
        --purple-500: #a855f7;
        --purple-600: #9333ea;
        --purple-700: #7c3aed;
        --purple-800: #6b21a8;
        --purple-900: #581c87;

        --amber-400: #fbbf24;
        --amber-500: #f59e0b;

        --green-500: #22c55e;
        --green-600: #16a34a;
        --green-700: #15803d;

        --warm-50: #fffbf7;
        --warm-100: #fef3eb;
        --warm-200: #fde8d8;
        --warm-800: #3d2209;

        --gray-50:  #fafafa;
        --gray-100: #f5f5f5;
        --gray-200: #e5e5e5;
        --gray-300: #d4d4d4;
        --gray-400: #a3a3a3;
        --gray-500: #737373;
        --gray-600: #525252;
        --gray-700: #404040;
        --gray-800: #262626;
        --gray-900: #171717;

        --shadow-sm: 0 1px 3px rgba(0,0,0,.05);
        --shadow:    0 4px 20px rgba(0,0,0,.06);
        --shadow-lg: 0 12px 40px rgba(0,0,0,.1);
        --shadow-xl: 0 20px 60px rgba(0,0,0,.12);
        --radius:    1rem;
        --radius-sm: 0.625rem;
        --radius-lg: 1.5rem;
      }

      html {
        scroll-behavior: smooth;
        font-size: 16px;
      }

      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
        color: var(--gray-800);
        line-height: 1.7;
        background: #fff;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }

      img {
        max-width: 100%;
        height: auto;
        display: block;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .container {
        max-width: 1080px;
        margin: 0 auto;
        padding: 0 2rem;
      }

      .section {
        padding: 6rem 0;
      }

      h1, h2, h3, h4 {
        line-height: 1.2;
        font-weight: 800;
        color: var(--gray-900);
      }

      .heading-serif {
        font-family: 'Playfair Display', Georgia, serif;
        font-weight: 700;
      }

      h2 {
        font-size: clamp(1.75rem, 4vw, 2.75rem);
      }

      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        font-size: 1.0625rem;
        font-weight: 700;
        padding: 1rem 2.25rem;
        border-radius: 999px;
        text-decoration: none;
        transition: all 0.25s ease;
        cursor: pointer;
        border: none;
        line-height: 1.2;
        font-family: inherit;
      }

      .btn--primary {
        background: linear-gradient(135deg, var(--rose-500), var(--purple-600));
        color: #fff;
        box-shadow: 0 4px 20px rgba(244,63,94,.3);
      }

      .btn--primary:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 30px rgba(244,63,94,.4);
      }

      .btn--primary:active {
        transform: translateY(-1px);
      }

      .btn--lg {
        font-size: 1.1875rem;
        padding: 1.125rem 2.75rem;
      }

      .btn--xl {
        font-size: 1.25rem;
        padding: 1.25rem 3rem;
      }

      .btn--outline {
        background: transparent;
        border: 2px solid var(--gray-200);
        color: var(--gray-700);
      }

      .btn--outline:hover {
        border-color: var(--rose-400);
        color: var(--rose-600);
        background: var(--rose-50);
      }

      .stars {
        color: var(--amber-400);
        letter-spacing: 0.05em;
        font-size: 1.1rem;
      }

      .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        background: var(--rose-50);
        color: var(--rose-700);
        font-size: 0.8125rem;
        font-weight: 700;
        padding: 0.375rem 0.875rem;
        border-radius: 999px;
        letter-spacing: 0.02em;
      }

      .text-center { text-align: center; }

      @media (max-width: 768px) {
        .container { padding: 0 1.5rem; }
        .section { padding: 4rem 0; }
        .btn--xl { font-size: 1.125rem; padding: 1rem 2rem; }
      }

      @media (max-width: 480px) {
        .container { padding: 0 1.25rem; }
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
