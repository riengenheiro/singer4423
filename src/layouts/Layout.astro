---
export interface Props {
  title: string;
  description: string;
  image?: string;
  canonical?: string;
  type?: string;
}

const {
  title,
  description,
  image = 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1200&h=630&fit=crop&q=80',
  canonical,
  type = 'website',
} = Astro.props;

const siteUrl = 'https://singer4423.escolhacertabrasil.com.br';
const canonicalURL = canonical ?? Astro.url.href;
const ogImage = image.startsWith('http') ? image : `${siteUrl}${image}`;

const schemaProduct = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Singer Facilita Pro 4423 220V',
  description:
    'Máquina de Costura Singer Facilita Pro 4423 com 23 pontos, 1100 pontos por minuto, passador automático e casa de botão automática.',
  brand: { '@type': 'Brand', name: 'Singer' },
  sku: 'B07Y8NSHCJ',
  model: 'Facilita Pro 4423',
  color: 'Branco',
  material: 'Metal',
  offers: {
    '@type': 'Offer',
    url: 'https://amzn.to/4dObHF0',
    priceCurrency: 'BRL',
    availability: 'https://schema.org/InStock',
    seller: { '@type': 'Organization', name: 'Amazon' },
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.8',
    reviewCount: '2798',
    bestRating: '5',
    worstRating: '1',
  },
});
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#166534" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.svg" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Singer Facilita Pro 4423 — A máquina que transforma iniciantes" />
    <meta property="og:site_name" content="Escolha Certa Brasil" />
    <meta property="og:locale" content="pt_BR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Singer Facilita Pro 4423" />

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={schemaProduct} />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://images.unsplash.com" />
    <link rel="dns-prefetch" href="https://amzn.to" />

    <style>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --green-900: #14532d;
        --green-800: #166534;
        --green-700: #15803d;
        --green-600: #16a34a;
        --green-100: #dcfce7;
        --green-50:  #f0fdf4;
        --red-600:   #dc2626;
        --red-50:    #fef2f2;
        --amber-400: #fbbf24;
        --amber-500: #f59e0b;
        --gray-50:   #f9fafb;
        --gray-100:  #f3f4f6;
        --gray-200:  #e5e7eb;
        --gray-300:  #d1d5db;
        --gray-500:  #6b7280;
        --gray-600:  #4b5563;
        --gray-700:  #374151;
        --gray-800:  #1f2937;
        --gray-900:  #111827;
        --shadow-sm: 0 1px 2px rgba(0,0,0,.06);
        --shadow:    0 4px 16px rgba(0,0,0,.08);
        --shadow-lg: 0 8px 32px rgba(0,0,0,.12);
        --radius:    0.75rem;
      }

      html {
        scroll-behavior: smooth;
        font-size: 16px;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
        color: var(--gray-900);
        line-height: 1.65;
        background: #fff;
        -webkit-font-smoothing: antialiased;
      }

      img {
        max-width: 100%;
        height: auto;
        display: block;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 1.25rem;
      }

      .section {
        padding: 5rem 0;
      }

      .section--alt {
        background: var(--gray-50);
      }

      .section--green {
        background: var(--green-800);
        color: #fff;
      }

      .section--dark {
        background: var(--gray-900);
        color: #fff;
      }

      h1, h2, h3, h4 {
        line-height: 1.2;
        font-weight: 800;
      }

      h2 {
        font-size: clamp(1.75rem, 4vw, 2.5rem);
        color: var(--gray-900);
      }

      h3 {
        font-size: 1.2rem;
        font-weight: 700;
      }

      /* Buttons */
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        font-size: 1.0625rem;
        font-weight: 700;
        padding: 0.875rem 2rem;
        border-radius: var(--radius);
        text-decoration: none;
        transition: all 0.2s ease;
        cursor: pointer;
        border: none;
        line-height: 1;
        white-space: nowrap;
      }

      .btn--primary {
        background: var(--green-600);
        color: #fff;
        box-shadow: 0 4px 14px rgba(22,163,74,.4);
      }

      .btn--primary:hover {
        background: var(--green-700);
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(22,163,74,.45);
      }

      .btn--primary:active {
        transform: translateY(0);
      }

      .btn--lg {
        font-size: 1.25rem;
        padding: 1rem 2.5rem;
      }

      .btn--xl {
        font-size: 1.375rem;
        padding: 1.125rem 3rem;
        border-radius: 999px;
      }

      /* Stars */
      .stars {
        color: var(--amber-400);
        letter-spacing: 0.05em;
        font-size: 1.1rem;
      }

      /* Badge */
      .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        background: var(--green-100);
        color: var(--green-800);
        font-size: 0.8125rem;
        font-weight: 700;
        padding: 0.25rem 0.75rem;
        border-radius: 999px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      /* Cards */
      .card {
        background: #fff;
        border-radius: var(--radius);
        padding: 1.75rem;
        box-shadow: var(--shadow);
        border: 1px solid var(--gray-100);
      }

      /* Utilities */
      .text-center { text-align: center; }
      .text-green  { color: var(--green-700); }
      .text-red    { color: var(--red-600); }
      .text-muted  { color: var(--gray-500); }
      .font-bold   { font-weight: 700; }
      .mt-1  { margin-top: 0.25rem; }
      .mt-2  { margin-top: 0.5rem; }
      .mt-3  { margin-top: 0.75rem; }
      .mt-4  { margin-top: 1rem; }
      .mt-6  { margin-top: 1.5rem; }
      .mt-8  { margin-top: 2rem; }

      /* Responsive */
      @media (max-width: 768px) {
        .section { padding: 3rem 0; }
        .btn--xl { font-size: 1.125rem; padding: 1rem 2rem; }
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
