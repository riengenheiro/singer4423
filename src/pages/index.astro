---
import Layout from '../layouts/Layout.astro';

const AFFILIATE_URL = 'https://amzn.to/4dObHF0';

const features = [
  {
    icon: '💪',
    title: 'Costura Jeans e Moletom Sem Travar',
    desc: 'Motor potente com até 1.100 pontos por minuto. Tecidos grossos, duplos e pesados não são problema. Diga adeus à máquina que trava no meio do projeto.',
  },
  {
    icon: '🪡',
    title: 'Linha Passada em Segundos',
    desc: 'O passador automático elimina aquela frustração de ficar tentando enfiar a linha. Um movimento e está pronto. Economize tempo e energia para o que importa.',
  },
  {
    icon: '🔘',
    title: 'Casa de Botão Perfeita em 1 Passo',
    desc: 'A casa de botão automática cria acabamentos profissionais com apenas um movimento. Sem marcação, sem tentativa e erro, sem resultado torto.',
  },
  {
    icon: '✂️',
    title: 'Cortador de Linha Integrado',
    desc: 'Acabou a costura, cortou a linha na hora. Sem tesoura, sem interrupções. Seus projetos ficam prontos mais rápido e com acabamento limpo.',
  },
  {
    icon: '🌟',
    title: '23 Pontos Incorporados',
    desc: 'Do ponto reto ao ziguezague e overlock, você tem versatilidade total para qualquer projeto: roupas, bolsas, reparos, artesanato e muito mais.',
  },
  {
    icon: '💡',
    title: 'Área de Costura Iluminada',
    desc: 'Iluminação embutida que ilumina exatamente onde você precisa. Trabalhe com tecidos escuros, detalhes finos e projetos noturnos sem errar o ponto.',
  },
];

const reviews = [
  {
    name: 'Thais',
    stars: 5,
    text: 'Simplesmente perfeita. Comprei para minha mãe e ela amou!',
    date: 'Mai 2026',
  },
  {
    name: 'Kamylla Sansy',
    stars: 5,
    text: 'Maravilhosa, amei de mais. Chegou perfeita, super recomendo!',
    date: 'Mai 2026',
  },
  {
    name: 'Katianne Clesia',
    stars: 5,
    text: 'Muito linda, minha mãe amou o presente do Dia das Mães!!',
    date: 'Mai 2026',
  },
  {
    name: 'kemilly rayne',
    stars: 5,
    text: 'Máquina incrível, super rápida! Indico muito.',
    date: 'Mai 2026',
  },
  {
    name: 'L. SILVA',
    stars: 5,
    text: 'Excelente máquina de costura. Silenciosa e eficiente.',
    date: 'Mai 2026',
  },
  {
    name: 'Vladia',
    stars: 5,
    text: 'Comprei pra minha mãe e ela amou. Super rápida, fácil de manusear.',
    date: 'Mai 2026',
  },
  {
    name: 'Aline da Silva',
    stars: 5,
    text: 'Máquina muito boa, costura muito bem. Ótima para iniciantes.',
    date: 'Mai 2026',
  },
  {
    name: 'Leninha',
    stars: 5,
    text: 'Adorei a máquina, uso sempre. Chegou bem embalada e tudo certinho.',
    date: 'Mai 2026',
  },
];

const faqs = [
  {
    q: 'A Singer 4423 vale a pena?',
    a: 'Vale muito. É a máquina número 1 em vendas na Amazon Brasil com 4,8 estrelas e quase 3.000 avaliações verificadas. Ela combina potência real, facilidade de uso e versatilidade num preço justo. Para quem está começando ou quer uma máquina confiável para uso doméstico intenso, é a escolha certa.',
  },
  {
    q: 'A Singer 4423 costura jeans?',
    a: 'Sim! Com 1.100 pontos por minuto e motor de alta potência, ela costura jeans, moletom, lona e outros tecidos grossos sem travar. Muitos clientes relatam exatamente isso nas avaliações: "finalmente uma máquina forte de verdade".',
  },
  {
    q: 'É boa para quem está começando a costurar?',
    a: 'É uma das melhores opções para iniciantes. O passador de linha automático, a casa de botão em 1 passo e a iluminação embutida tornam o processo muito mais fácil. Você aprende rápido e já consegue resultados profissionais desde o início.',
  },
  {
    q: 'Qual voltagem? Funciona em 220V?',
    a: 'Sim, este modelo é 220V. Verifique a voltagem da sua tomada antes de comprar. Na página da Amazon você consegue selecionar o voltagem corretamente antes de adicionar ao carrinho.',
  },
  {
    q: 'Qual a garantia da Singer 4423?',
    a: '1 ano de garantia pelo fabricante (Singer). A máquina vem com manual de instruções com certificado de garantia incluído na caixa.',
  },
  {
    q: 'Quais acessórios vêm incluídos?',
    a: 'A Singer 4423 vem com: máquina de costura, controlador de velocidade (pedal), manual de instruções com certificado de garantia, capa protetora e acessórios da máquina (calcadores, agulhas extras, etc.).',
  },
];

const specs = [
  { label: 'Pontos incorporados', value: '23 tipos' },
  { label: 'Velocidade máxima', value: '1.100 pontos/min' },
  { label: 'Voltagem', value: '220V' },
  { label: 'Peso', value: '6,4 kg' },
  { label: 'Dimensões', value: '24,5 × 48 × 38 cm' },
  { label: 'Material', value: 'Metal' },
  { label: 'Garantia', value: '1 ano (fabricante)' },
  { label: 'Avaliação Amazon', value: '4,8 ★ (2.798 avaliações)' },
  { label: 'Ranking', value: '#1 em Máquinas de Costura' },
  { label: 'País de origem', value: 'Taiwan' },
];
---

<Layout
  title="Singer 4423 Vale a Pena? | A Máquina que Transforma Iniciantes em Costureiras Confiantes"
  description="Descubra por que a Singer Facilita Pro 4423 é a máquina #1 em vendas na Amazon. 23 pontos, 1.100 pts/min, passador automático. 4,8★ com 2.798 avaliações verificadas."
>

  <!-- HEADER -->
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="logo">
        <svg width="28" height="28" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="64" height="64" rx="14" fill="#166534"/>
          <rect x="30" y="8" width="4" height="28" rx="2" fill="#fff"/>
          <polygon points="30,36 34,36 32,44" fill="#fff"/>
          <rect x="20" y="46" width="24" height="12" rx="4" fill="#4ade80"/>
          <rect x="18" y="44" width="28" height="4" rx="2" fill="#bbf7d0"/>
          <rect x="18" y="54" width="28" height="4" rx="2" fill="#bbf7d0"/>
        </svg>
        <span>Escolha Certa Brasil</span>
      </a>
      <a href={AFFILIATE_URL} target="_blank" rel="noopener sponsored" class="btn btn--primary header-cta">
        Ver na Amazon
      </a>
    </div>
  </header>

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-content">
          <div class="badge">
            <span>★</span> #1 em Máquinas de Costura na Amazon
          </div>
          <h1 class="hero-title">
            A máquina que faz<br />
            <span class="hero-highlight">iniciantes se sentirem<br />profissionais</span>
          </h1>
          <p class="hero-desc">
            Pare de passar raiva com máquina fraca. A Singer 4423 costura jeans, moletom e qualquer tecido — com facilidade, velocidade e acabamento perfeito do primeiro dia.
          </p>
          <div class="hero-rating">
            <span class="stars">★★★★★</span>
            <span class="hero-rating-text"><strong>4,8 de 5</strong> — 2.798 avaliações verificadas</span>
          </div>
          <div class="hero-actions">
            <a href={AFFILIATE_URL} target="_blank" rel="noopener sponsored" class="btn btn--primary btn--xl">
              🛒 Comprar na Amazon
            </a>
            <p class="hero-note">⚡ Entrega rápida • Frete grátis Prime • Garantia 1 ano</p>
          </div>
        </div>
        <div class="hero-image-wrap">
          <img
            src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=700&h=600&fit=crop&q=85"
            alt="Singer Facilita Pro 4423 — Máquina de Costura"
            width="700"
            height="600"
            loading="eager"
            fetchpriority="high"
            class="hero-img"
          />
          <div class="hero-badge-float">
            <span class="hbf-stars">★★★★★</span>
            <span class="hbf-count">2.798 avaliações</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <div class="trust-bar">
    <div class="container trust-bar-inner">
      <div class="trust-item">
        <span class="trust-icon">🏆</span>
        <span>#1 em Máquinas de Costura</span>
      </div>
      <div class="trust-item">
        <span class="trust-icon">⭐</span>
        <span>4,8 / 5 estrelas</span>
      </div>
      <div class="trust-item">
        <span class="trust-icon">✅</span>
        <span>2.798 avaliações verificadas</span>
      </div>
      <div class="trust-item">
        <span class="trust-icon">🚚</span>
        <span>Entrega pela Amazon</span>
      </div>
      <div class="trust-item">
        <span class="trust-icon">🔒</span>
        <span>Garantia 1 ano Singer</span>
      </div>
    </div>
  </div>

  <!-- PROBLEMA / AGITAÇÃO -->
  <section class="section">
    <div class="container">
      <div class="problem-wrap">
        <div class="problem-text">
          <span class="section-label">Você já passou por isso?</span>
          <h2>Quando a máquina não acompanha a sua vontade de costurar</h2>
          <p>A frustração de comprar uma máquina e ela não dar conta dos projetos que você imaginou é real. Trava no jeans. A linha cai na hora errada. O ponto fica torto. A casa de botão nunca sai reta.</p>
          <ul class="problem-list">
            <li>😤 Máquina trava no meio do tecido grosso</li>
            <li>🧵 Horas tentando enfiar a linha na agulha</li>
            <li>😞 Acabamento que nunca fica igual ao do tutorial</li>
            <li>⏳ Projetos parados porque a máquina não aguentou</li>
          </ul>
          <p class="problem-solution"><strong>Isso acaba com a Singer 4423.</strong></p>
        </div>
        <div class="problem-image">
          <img
            src="https://images.unsplash.com/photo-1585914924626-15adac1e6402?w=550&h=450&fit=crop&q=80"
            alt="Costura com tecidos variados"
            width="550"
            height="450"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="section section--alt">
    <div class="container">
      <div class="text-center mb-10">
        <span class="section-label">O que você ganha</span>
        <h2>Tudo que você precisa para costurar com confiança</h2>
        <p class="section-sub">Cada detalhe da Singer 4423 foi pensado para eliminar as travações, facilitar o processo e entregar resultados que impressionam.</p>
      </div>
      <div class="features-grid">
        {features.map((f) => (
          <div class="feature-card">
            <div class="feature-icon">{f.icon}</div>
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href={AFFILIATE_URL} target="_blank" rel="noopener sponsored" class="btn btn--primary btn--lg">
          🛒 Ver Singer 4423 na Amazon →
        </a>
      </div>
    </div>
  </section>

  <!-- FOTOS / LIFESTYLE -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-10">
        <span class="section-label">Na prática</span>
        <h2>Feita para cada projeto que você sonha fazer</h2>
        <p class="section-sub">Da primeira costura ao projeto mais desafiador — a Singer 4423 está pronta para acompanhar sua evolução.</p>
      </div>
      <div class="gallery-grid">
        <div class="gallery-item gallery-item--tall">
          <img
            src="https://images.unsplash.com/photo-1526045612212-70caf35c14df?w=600&h=750&fit=crop&q=80"
            alt="Costurando tecido colorido na máquina de costura"
            width="600"
            height="750"
            loading="lazy"
          />
          <div class="gallery-caption">Tecidos coloridos e estampados</div>
        </div>
        <div class="gallery-col">
          <div class="gallery-item">
            <img
              src="https://images.unsplash.com/photo-1467043237213-65f2da53396f?w=600&h=380&fit=crop&q=80"
              alt="Linha e agulha para costura"
              width="600"
              height="380"
              loading="lazy"
            />
            <div class="gallery-caption">Detalhes precisos e acabamento perfeito</div>
          </div>
          <div class="gallery-item">
            <img
              src="https://images.unsplash.com/photo-1617881770125-6fb0d039ecb1?w=600&h=380&fit=crop&q=80"
              alt="Costura de tecido grosso"
              width="600"
              height="380"
              loading="lazy"
            />
            <div class="gallery-caption">Moletom, jeans e tecidos pesados</div>
          </div>
        </div>
        <div class="gallery-item gallery-item--tall">
          <img
            src="https://images.unsplash.com/photo-1483985988355-763728e1935b?w=600&h=750&fit=crop&q=80"
            alt="Criações de costura — roupas feitas em casa"
            width="600"
            height="750"
            loading="lazy"
          />
          <div class="gallery-caption">Criações que geram orgulho (e renda)</div>
        </div>
      </div>
    </div>
  </section>

  <!-- TRANSFORMAÇÃO -->
  <section class="section section--green">
    <div class="container">
      <div class="transform-grid">
        <div class="transform-text">
          <span class="section-label-light">A transformação real</span>
          <h2 style="color:#fff;">De "minha primeira máquina séria" a costureira confiante</h2>
          <p style="color:#bbf7d0;margin-top:1rem;">Costurar não é só uma habilidade. É independência. É satisfação de criar com as próprias mãos. É parar de pagar caro por consertos e customizações.</p>
          <ul class="transform-list">
            <li>✅ Consertar e reformar roupas em casa</li>
            <li>✅ Criar peças exclusivas do zero</li>
            <li>✅ Fazer renda extra vendendo o que cria</li>
            <li>✅ Dar presentes feitos à mão com amor</li>
            <li>✅ Desenvolver um hobby lucrativo e criativo</li>
          </ul>
          <a href={AFFILIATE_URL} target="_blank" rel="noopener sponsored" class="btn btn--light btn--lg mt-8" style="background:#fff;color:var(--green-800);">
            Quero começar agora →
          </a>
        </div>
        <div class="transform-stats">
          <div class="stat-card">
            <div class="stat-number">4,8<span class="stat-sup">★</span></div>
            <div class="stat-label">Avaliação média na Amazon</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">2.798</div>
            <div class="stat-label">Avaliações verificadas</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">#1</div>
            <div class="stat-label">Em Máquinas de Costura</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">23</div>
            <div class="stat-label">Tipos de ponto incluídos</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="section section--alt">
    <div class="container">
      <div class="text-center mb-10">
        <span class="section-label">Avaliações reais</span>
        <h2>O que as clientes estão dizendo</h2>
        <p class="section-sub">Avaliações verificadas de compradoras na Amazon Brasil — pessoas reais com experiências reais.</p>
      </div>
      <div class="reviews-grid">
        {reviews.map((r) => (
          <div class="review-card card">
            <div class="review-stars stars">{"★".repeat(r.stars)}</div>
            <p class="review-text">"{r.text}"</p>
            <div class="review-footer">
              <span class="review-name">{r.name}</span>
              <span class="review-date">{r.date}</span>
            </div>
          </div>
        ))}
      </div>
      <div class="reviews-cta text-center mt-10">
        <p class="reviews-total">Mais de <strong>2.798 avaliações verificadas</strong> com média de <strong>4,8 estrelas</strong></p>
        <a href={AFFILIATE_URL} target="_blank" rel="noopener sponsored" class="btn btn--primary btn--lg mt-4">
          Ver todas as avaliações na Amazon
        </a>
      </div>
    </div>
  </section>

  <!-- ESPECIFICAÇÕES -->
  <section class="section">
    <div class="container">
      <div class="specs-wrap">
        <div class="specs-text">
          <span class="section-label">Ficha técnica</span>
          <h2>Singer Facilita Pro 4423 — Especificações</h2>
          <p class="mt-4">Para quem quer saber os detalhes técnicos antes de comprar, aqui está tudo sobre a Singer 4423:</p>
          <table class="specs-table">
            <tbody>
              {specs.map((s) => (
                <tr>
                  <td class="spec-label">{s.label}</td>
                  <td class="spec-value">{s.value}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <div class="specs-image">
          <img
            src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=500&h=500&fit=crop&q=80"
            alt="Detalhe da Singer Facilita Pro 4423"
            width="500"
            height="500"
            loading="lazy"
          />
          <div class="specs-badge">
            <div class="specs-badge-rating">★★★★★</div>
            <div class="specs-badge-text">Nota 4,8 — Amazon BR</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--alt">
    <div class="container">
      <div class="text-center mb-10">
        <span class="section-label">Perguntas frequentes</span>
        <h2>Tudo que você quer saber sobre a Singer 4423</h2>
      </div>
      <div class="faq-list">
        {faqs.map((faq, i) => (
          <details class="faq-item" open={i === 0}>
            <summary class="faq-question">
              <span>{faq.q}</span>
              <span class="faq-icon">+</span>
            </summary>
            <div class="faq-answer">
              <p>{faq.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="section section--dark">
    <div class="container text-center">
      <span class="section-label-light">Pronta para dar o próximo passo?</span>
      <h2 style="color:#fff;margin-top:0.75rem;">Sua primeira costura séria começa aqui</h2>
      <p style="color:#d1d5db;max-width:600px;margin:1.25rem auto 0;">
        A Singer 4423 é usada por milhares de costureiras no Brasil. É a escolha certa para quem quer qualidade, facilidade e resultados que impressionam — desde o primeiro dia.
      </p>
      <div class="final-cta-rating" style="margin-top:1.5rem;">
        <span class="stars" style="font-size:1.5rem;">★★★★★</span>
        <span style="color:#d1d5db;margin-left:0.5rem;">4,8 de 5 — 2.798 avaliações na Amazon</span>
      </div>
      <a
        href={AFFILIATE_URL}
        target="_blank"
        rel="noopener sponsored"
        class="btn btn--primary btn--xl"
        style="margin-top:2rem;"
      >
        🛒 Comprar Singer 4423 na Amazon
      </a>
      <p style="color:#6b7280;font-size:0.875rem;margin-top:1rem;">
        Entrega rápida • Pagamento seguro • Garantia 1 ano do fabricante
      </p>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/" class="logo">
            <svg width="24" height="24" viewBox="0 0 64 64" fill="none"><rect width="64" height="64" rx="14" fill="#166534"/><rect x="30" y="8" width="4" height="28" rx="2" fill="#fff"/><polygon points="30,36 34,36 32,44" fill="#fff"/><rect x="20" y="46" width="24" height="12" rx="4" fill="#4ade80"/><rect x="18" y="44" width="28" height="4" rx="2" fill="#bbf7d0"/><rect x="18" y="54" width="28" height="4" rx="2" fill="#bbf7d0"/></svg>
            <span>Escolha Certa Brasil</span>
          </a>
          <p class="footer-tagline">Ajudando você a fazer a escolha certa.</p>
        </div>
        <div class="footer-links">
          <h4>Links úteis</h4>
          <ul>
            <li><a href={AFFILIATE_URL} target="_blank" rel="noopener sponsored">Ver na Amazon</a></li>
            <li><a href="/politica-de-privacidade">Política de Privacidade</a></li>
            <li><a href="/termos-de-uso">Termos de Uso</a></li>
          </ul>
        </div>
        <div class="footer-disclosure">
          <h4>Divulgação de afiliado</h4>
          <p>Este site participa do Programa de Afiliados da Amazon. Quando você compra através dos nossos links, recebemos uma comissão sem custo adicional para você. Isso nos ajuda a continuar publicando conteúdo gratuito.</p>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© {new Date().getFullYear()} Escolha Certa Brasil. Todos os direitos reservados.</p>
        <p>Singer® e Facilita Pro 4423® são marcas registradas da Singer Company. Este site não é afiliado oficialmente à Singer.</p>
      </div>
    </div>
  </footer>

</Layout>

<style>
  /* HEADER */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: #fff;
    border-bottom: 1px solid var(--gray-200);
    box-shadow: var(--shadow-sm);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.875rem;
    padding-bottom: 0.875rem;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-weight: 800;
    font-size: 1rem;
    color: var(--gray-900);
    text-decoration: none;
  }
  .header-cta {
    font-size: 0.9375rem;
    padding: 0.625rem 1.25rem;
  }

  /* HERO */
  .hero {
    background: linear-gradient(135deg, #052e16 0%, #14532d 50%, #166534 100%);
    color: #fff;
    padding: 5rem 0 4rem;
    overflow: hidden;
    position: relative;
  }
  .hero::before {
    content: '';
