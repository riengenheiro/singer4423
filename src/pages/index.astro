---
const AFFILIATE_URL = 'https://amzn.to/4dObHF0';
const SITE_URL = 'https://singer4423.escolhacertabrasil.com.br';
const OG_IMAGE = `${SITE_URL}/images/singer-4423-compartilhamento.webp`;

const title = 'Singer 4423 vale a pena? Máquina forte para costurar jeans e começar direito';
const description =
  'Conheça a Singer Facilita Pro 4423 220V: 23 pontos, 1100 pontos/minuto, passador automático, casa de botão automática e 4,8 estrelas na Amazon.';

const benefits = [
  {
    title: 'Para parar de brigar com tecido grosso',
    text: 'A 4423 tem motor forte e estrutura de metal. É uma máquina doméstica feita para aguentar jeans, moletom, sarja e reparos do dia a dia.',
  },
  {
    title: 'Para começar sem medo',
    text: 'Passador automático, luz na área de costura e casa de botão em 1 passo deixam a curva de aprendizado bem mais leve.',
  },
  {
    title: 'Para ter acabamento mais bonito',
    text: 'São 23 pontos, ajuste de comprimento e largura, ponto firme e velocidade para produzir melhor sem perder controle.',
  },
];

const reviews = [
  ['Thais', 'Comprei para minha mãe, ela amou!'],
  ['Aline', 'Máquina muito boa, costura muito bem, ótima para iniciantes.'],
  ['Taziane', 'É maravilhosa, a máquina é potente, ponto bem certinho.'],
  ['Vladia', 'Super rápida, fácil de manusear.'],
];

const specs = [
  ['Modelo', 'Singer Facilita Pro 4423'],
  ['Voltagem', '220V'],
  ['Pontos', '23 pontos'],
  ['Velocidade', '1100 pontos/minuto'],
  ['Casa de botão', 'Automática'],
  ['Peso', '6,4 kg'],
  ['Garantia', '1 ano pelo fabricante'],
  ['Avaliação', '4,8/5 com 2.798 avaliações'],
];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#111827" />
    <link rel="canonical" href="https://singer4423.escolhacertabrasil.com.br/" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://singer4423.escolhacertabrasil.com.br/" />
    <meta property="og:image" content={OG_IMAGE} />
    <meta property="og:locale" content="pt_BR" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={OG_IMAGE} />

    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Product',
      name: 'Máquina de Costura Singer Facilita Pro 4423 220V',
      brand: { '@type': 'Brand', name: 'Singer' },
      model: 'Facilita Pro 4423',
      sku: 'B07Y8NSHCJ',
      description,
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '4.8',
        reviewCount: '2798',
      },
      offers: {
        '@type': 'Offer',
        url: AFFILIATE_URL,
        priceCurrency: 'BRL',
        availability: 'https://schema.org/InStock',
      },
    })} />
  </head>

  <body>
    <main class="site">
      <header class="header">
        <a href="/" class="brand">Escolha Certa Brasil</a>
        <a href={AFFILIATE_URL} target="_blank" rel="noopener sponsored" class="header-link">Ver na Amazon</a>
      </header>

      <section class="hero">
        <div class="hero-copy">
          <p class="tag">Singer Facilita Pro 4423 220V</p>
          <h1>A máquina para quem quer costurar sem passar raiva.</h1>
          <p class="lead">
            Forte para jeans, simples para iniciantes e bem avaliada por quem compra de verdade.
            A Singer 4423 é uma máquina doméstica para começar direito e evoluir sem medo.
          </p>

          <div class="actions">
            <a href={AFFILIATE_URL} target="_blank" rel="noopener sponsored" class="button">Ver preço na Amazon</a>
            <a href="#analise" class="button ghost">Ler análise</a>
          </div>

          <p class="proof">4,8 de 5 estrelas · 2.798 avaliações · #1 em Máquinas de Costura</p>
        </div>

        <figure class="hero-card">
          <img
            src="/images/singer-4423-hero.webp"
            alt="Máquina de costura Singer Facilita Pro 4423"
            width="720"
            height="760"
          />
          <figcaption>23 pontos · 1100 pontos/min · passador automático</figcaption>
        </figure>
      </section>

      <section class="section narrow" id="analise">
        <p class="tag">Resumo direto</p>
        <h2>Vale a pena se você quer uma máquina forte, mas não complicada.</h2>
        <p>
          O erro de muita gente é comprar uma máquina fraca para “começar barato” e depois descobrir
          que ela trava, pula ponto e não passa em tecido grosso. A Singer 4423 fica num ponto melhor:
          ainda é doméstica, mas tem força para projetos mais sérios.
        </p>
        <p>
          Ela conversa bem com quem está começando porque reduz fricção: passa linha com facilidade,
          ilumina a área de costura, faz casa de botão automática e entrega pontos firmes sem parecer
          uma máquina profissional difícil de entender.
        </p>
      </section>

      <section class="section">
        <div class="cards">
          {benefits.map((item) => (
            <article class="card">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section photos">
        <img
          src="/images/costura-tecidos-coloridos.webp"
          alt="Costura com tecidos coloridos"
          width="760"
          height="520"
          loading="lazy"
        />
        <img
          src="/images/costura-tecido-grosso.webp"
          alt="Costura em tecido grosso"
          width="760"
          height="520"
          loading="lazy"
        />
      </section>

      <section class="section narrow quote">
        <h2>Ela é para quem quer sentir: “agora eu consigo”.</h2>
        <p>
          Costurar melhor não depende só de talento. Depende de ter uma máquina que não atrapalha.
          E é exatamente isso que torna a Singer 4423 tão querida.
        </p>
      </section>

      <section class="section">
        <div class="section-title">
          <p class="tag">Avaliações reais</p>
          <h2>O que clientes dizem</h2>
        </div>

        <div class="reviews">
          {reviews.map(([name, text]) => (
            <article class="review">
              <span>★★★★★</span>
              <p>“{text}”</p>
              <strong>{name}</strong>
            </article>
          ))}
        </div>
      </section>

      <section class="section specs">
        <div>
          <p class="tag">Ficha técnica</p>
          <h2>Detalhes do produto</h2>
        </div>

        <dl>
          {specs.map(([label, value]) => (
            <div>
              <dt>{label}</dt>
              <dd>{value}</dd>
            </div>
          ))}
        </dl>
      </section>

      <section class="section buy">
        <h2>Se você quer começar com uma máquina que aguenta, essa é uma escolha segura.</h2>
        <p>
          Compra pela Amazon, com avaliações verificadas, entrega rápida e garantia de 1 ano pelo fabricante.
        </p>
        <a href={AFFILIATE_URL} target="_blank" rel="noopener sponsored" class="button">Comprar pela Amazon</a>
        <small>Este site usa links de afiliado. Podemos receber comissão sem custo extra para você.</small>
      </section>

      <footer class="footer">
        <span>© {new Date().getFullYear()} Escolha Certa Brasil</span>
        <nav>
          <a href="/politica-de-privacidade">Política</a>
          <a href="/termos-de-uso">Termos</a>
        </nav>
      </footer>
    </main>
  </body>
</html>

<style>
  :root {
    --bg: #f3eee7;
    --paper: #fffaf3;
    --ink: #1f2937;
    --muted: #667085;
    --line: #e6ded4;
    --soft: #f8efe3;
    --gold: #b7791f;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--ink);
    font-family: Arial, Helvetica, sans-serif;
    line-height: 1.6;
  }

  img {
    max-width: 100%;
    display: block;
  }

  a {
    color: inherit;
  }

  .site {
    width: min(100% - 40px, 980px);
    margin: 24px auto;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 24px 80px rgba(31, 41, 55, 0.08);
  }

  .header,
  .hero,
  .section,
  .footer {
    width: min(100% - 72px, 840px);
    margin-inline: auto;
  }

  .header {
    min-height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    border-bottom: 1px solid var(--line);
  }

  .brand,
  .header-link,
  .button,
  .footer a {
    text-decoration: none;
    font-weight: 700;
  }

  .brand {
    font-size: 0.95rem;
  }

  .header-link {
    color: var(--gold);
    font-size: 0.9rem;
  }

  .hero {
    display: grid;
    grid-template-columns: 1.08fr 0.92fr;
    gap: 44px;
    align-items: center;
    padding: 64px 0;
  }

  .tag {
    margin: 0 0 12px;
    color: var(--gold);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    margin-bottom: 22px;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(2.35rem, 6vw, 4.35rem);
    line-height: 0.96;
    letter-spacing: -0.055em;
  }

  h2 {
    margin-bottom: 16px;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(1.75rem, 4vw, 2.8rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
  }

  h3 {
    margin-bottom: 8px;
    font-size: 1.05rem;
    line-height: 1.25;
  }

  p {
    color: var(--muted);
    font-size: 1.05rem;
  }

  .lead {
    margin-bottom: 28px;
    font-size: 1.18rem;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 20px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 50px;
    padding: 0 22px;
    border-radius: 999px;
    background: var(--ink);
    color: white;
    border: 1px solid var(--ink);
  }

  .button.ghost {
    background: transparent;
    color: var(--ink);
  }

  .proof {
    margin: 0;
    padding-left: 16px;
    border-left: 3px solid var(--gold);
    font-size: 0.9rem;
  }

  .hero-card {
    margin: 0;
    padding: 14px;
    background: var(--soft);
    border: 1px solid var(--line);
    border-radius: 20px;
  }

  .hero-card img {
    width: 100%;
    aspect-ratio: 1 / 1.08;
    object-fit: cover;
    border-radius: 14px;
  }

  .hero-card figcaption {
    padding: 14px 4px 2px;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .section {
    padding: 64px 0;
    border-top: 1px solid var(--line);
  }

  .narrow {
    width: min(100% - 72px, 700px);
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .card,
  .review {
    background: white;
    border: 1px solid var(--line);
    border-radius: 18px;
    padding: 22px;
  }

  .card p,
  .review p {
    margin-bottom: 0;
    font-size: 0.98rem;
  }

  .photos {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .photos img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 18px;
    border: 1px solid var(--line);
  }

  .quote {
    text-align: center;
  }

  .reviews {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
  }

  .review span {
    display: block;
    margin-bottom: 10px;
    color: #d97706;
    font-size: 0.86rem;
    letter-spacing: 0.04em;
  }

  .review strong {
    display: block;
    margin-top: 12px;
    font-size: 0.86rem;
  }

  .specs {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 36px;
  }

  dl {
    margin: 0;
    border-top: 1px solid var(--line);
  }

  dl div {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 16px;
    padding: 12px 0;
    border-bottom: 1px solid var(--line);
  }

  dt {
    color: var(--muted);
    font-size: 0.9rem;
  }

  dd {
    margin: 0;
    font-weight: 700;
  }

  .buy {
    text-align: center;
  }

  .buy p {
    max-width: 620px;
    margin-inline: auto;
    margin-bottom: 24px;
  }

  .buy small {
    display: block;
    margin-top: 14px;
    color: var(--muted);
    font-size: 0.78rem;
  }

  .footer {
    min-height: 78px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.86rem;
  }

  .footer nav {
    display: flex;
    gap: 16px;
  }

  @media (max-width: 820px) {
    .hero,
    .specs {
      grid-template-columns: 1fr;
    }

    .cards,
    .reviews {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 620px) {
    .site {
      width: calc(100% - 16px);
      margin: 8px auto;
      border-radius: 18px;
    }

    .header,
    .hero,
    .section,
    .narrow,
    .footer {
      width: calc(100% - 32px);
    }

    .header,
    .footer {
      align-items: flex-start;
      flex-direction: column;
      justify-content: center;
      padding: 18px 0;
    }

    .hero,
    .section {
      padding: 46px 0;
    }

    .actions,
    .photos,
    .cards,
    .reviews {
      grid-template-columns: 1fr;
    }

    .actions,
    .photos {
      display: grid;
    }

    .button {
      width: 100%;
    }

    dl div {
      grid-template-columns: 1fr;
      gap: 2px;
    }
  }
</style>
